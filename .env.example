# ──────────────────────────────────────────────────────────────
# Aetherius — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# Google Gemini API key (required for all LlmAgent calls)
GOOGLE_API_KEY=your_google_api_key_here

# Model to use for all agents (e.g. gemini-2.0-flash, gemini-1.5-pro)
AETHERIUS_MODEL=gemini-2.0-flash

# MCP server connection (stdio by default; update for SSE/networked mode)
MCP_TRANSPORT=stdio
# MCP_SERVER_URL=http://localhost:8080/sse   # uncomment for SSE transport

# Optional: set to DEBUG for verbose ADK / FastMCP logging
LOG_LEVEL=INFO
